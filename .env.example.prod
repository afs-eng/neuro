# ============================================================
# NeuroAvalia — Producao Self-Hosted (VPS + Docker Compose)
# ============================================================

# Django
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=<sua-chave-secreta-gerada>
ALLOWED_HOSTS=seu-dominio.com,www.seu-dominio.com
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com
CORS_ALLOWED_ORIGINS=https://frontend.seu-dominio.com

# PostgreSQL
POSTGRES_DB=neuro_db
POSTGRES_USER=neuro_user
POSTGRES_PASSWORD=<senha-forte-do-banco>

# URLs publicas
FRONTEND_BASE_URL=https://frontend.seu-dominio.com
BACKEND_PUBLIC_URL=https://api.seu-dominio.com

# IA (OpenRouter via API OpenAI-compatible)
AI_PROVIDER=openai
OPENAI_API_KEY=<sua-chave-openrouter>
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_REFERER=https://frontend.seu-dominio.com
OPENAI_TITLE=NeuroAvalia
OPENAI_MODEL_TEXT=google/gemma-4-31b-it:free
OPENAI_MODEL_REASONING=google/gemma-4-31b-it:free
OPENAI_FALLBACK_MODELS=google/gemma-3-27b-it:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-20b:free

# E-mail
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=NeuroAvalia <noreply@seu-dominio.com>

# WhatsApp (Evolution API — opcional)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
