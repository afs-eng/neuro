# ============================================================
# NeuroAvalia — Producao Self-Hosted (VPS + Docker Compose)
# ============================================================

# Django
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=<sua-chave-secreta-gerada>
ALLOWED_HOSTS=sistema.lapidarpsicologia.com.br
CSRF_TRUSTED_ORIGINS=https://sistema.lapidarpsicologia.com.br
CORS_ALLOWED_ORIGINS=https://sistema.lapidarpsicologia.com.br

# PostgreSQL
POSTGRES_DB=neuro_db
POSTGRES_USER=neuro_user
POSTGRES_PASSWORD=<senha-forte-do-banco>

# URLs publicas
FRONTEND_BASE_URL=https://sistema.lapidarpsicologia.com.br
BACKEND_PUBLIC_URL=https://sistema.lapidarpsicologia.com.br

# IA (OpenRouter via API OpenAI-compatible)
AI_PROVIDER=openai
OPENAI_API_KEY=<sua-chave-openrouter>
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_REFERER=https://sistema.lapidarpsicologia.com.br
OPENAI_TITLE=NeuroAvalia
OPENAI_MODEL_TEXT=google/gemma-4-31b-it:free
OPENAI_MODEL_REASONING=google/gemma-4-31b-it:free
OPENAI_FALLBACK_MODELS=google/gemma-3-27b-it:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-20b:free

# Opcional: Ollama em producao apenas se houver endpoint acessivel pelo servidor
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3.5:27b

# E-mail
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=NeuroAvalia <noreply@lapidarpsicologia.com.br>

# WhatsApp (Evolution API — opcional)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
