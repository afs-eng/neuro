#==================================================
# POSTGRESQL (Docker Compose)
#==================================================
POSTGRES_DB=neuroavalia
POSTGRES_USER=neuro_user
POSTGRES_PASSWORD=neuro_pass

#==================================================
# DJANGO BACKEND CONFIG (Para production.py e compose)
#==================================================
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=django-insecure-substitua-isso-em-producao-por-uma-chave-forte

# URL que o Django acessará o PostgreSQL dentro do Docker (db é o nome do container)
DATABASE_URL=postgres://neuro_user:neuro_pass@db:5432/neuroavalia
DATABASE_SSL_REQUIRE=False # Em docker interno n usamos TLS usualmente

# Hosts permitidos para o Backend
ALLOWED_HOSTS=127.0.0.1,localhost,backend,meudominio.com
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://meudominio.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://meudominio.com

# Usado para roteamento reverso de links em e-mails e permissões CORS
FRONTEND_BASE_URL=https://meudominio.com
BACKEND_PUBLIC_URL=https://api.meudominio.com

# Habilita previews da Vercel no backend em producao
ALLOW_VERCEL_PREVIEWS=True

#==================================================
# CONFIGURAÇÕES DE EMAIL E MENSAGERIA (Vazio = Mock/Console)
#==================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_HOST_USER=seu_email
EMAIL_HOST_PASSWORD=sua_senha
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@meudominio.com
